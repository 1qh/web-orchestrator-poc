{
  "name": "web-orchestrator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:e2e": "vitest run",
    "test:e2e:live": "tsx scripts/live-e2e.ts",
    "test:e2e:live:full": "tsx scripts/live-e2e-full.ts",
    "test:e2e:live:trigger": "tsx scripts/live-e2e-trigger.ts",
    "test:e2e:proof:selfhost": "tsx scripts/live-e2e-proof.ts",
    "trigger:selfhost:start": "tsx scripts/trigger-selfhost/start.ts",
    "trigger:selfhost:reset": "tsx scripts/trigger-selfhost/reset.ts",
    "trigger:selfhost:status": "tsx scripts/trigger-selfhost/status.ts",
    "trigger:selfhost:bootstrap": "tsx scripts/trigger-selfhost/bootstrap.ts",
    "trigger:selfhost:worker-token": "tsx scripts/trigger-selfhost/worker-token.ts",
    "trigger:selfhost:stop": "tsx scripts/trigger-selfhost/stop.ts",
    "test:all": "bun test && vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/lib/db/run-migrations.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/react": "^3.0.118",
    "@base-ui/react": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@trigger.dev/sdk": "^4.4.3",
    "ai": "^6.0.116",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shadcn": "^4.0.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bun-types": "^1.3.10",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "better-sqlite3",
    "sharp",
    "unrs-resolver"
  ]
