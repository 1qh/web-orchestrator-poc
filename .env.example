# Copy to .env.local and fill values locally.
# Do not commit real credentials.

# Accepts either name. App auto-aliases GOOGLE_VERTEX_API_KEY -> GOOGLE_GENERATIVE_AI_API_KEY.
GOOGLE_VERTEX_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Self-hosted defaults
USE_TRIGGER_DEV=false
DB_FILE_PATH=.data/web-orchestrator.sqlite

# Trigger.dev (required only for real Trigger transport verification)
TRIGGER_PROJECT_REF=
TRIGGER_SECRET_KEY=
# Optional override for Trigger API endpoint
TRIGGER_API_URL=
TRIGGER_ACCESS_TOKEN=

# Callback secret used by /api/internal/background-callback when USE_TRIGGER_DEV=true
BACKGROUND_CALLBACK_SECRET=

# Optional MCP server config (JSON array)
MCP_SERVERS_JSON=[]

# Optional model overrides
ORCHESTRATOR_MODEL=gemini-2.5-flash
GROUNDING_MODEL=gemini-2.5-flash

# Optional live-e2e ports
E2E_PORT=3421
E2E_TRIGGER_PORT=3431
E2E_MCP_PORT=3591
